    "/notifications/notification-center/v1/routers:testCondition": {
      "post": {
        "tags": [
          "Notifications testing service"
        ],
        "summary": "Test Routing Condition Valid",
        "description": "Tests notification routing conditions.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "TestingService_TestRoutingConditionValid",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Test Routing Condition Valid Request",
                "description": "Request to check that provided routing condition is valid",
                "type": "object",
                "properties": {
                  "entityType": {
                    "$ref": "#/components/schemas/notification_center.EntityType"
                  },
                  "template": {
                    "example": "alertDef.priority == 'P1'",
                    "description": "Routing condition expression to validate.",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestRoutingConditionValidResponse"
                }
              }
            }
          }
        }
      }
    },
    "/notifications/notification-center/v1/templates:test": {
      "post": {
