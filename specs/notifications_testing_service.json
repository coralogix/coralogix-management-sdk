        "summary": "Test Existing Connector",
        "description": "Sends a test notification.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "TestingService_TestExistingConnector",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "description": "Request for sending a test notification.",
                "type": "object",
                "properties": {
                  "connectorId": {
                    "description": "The connector id.",
                    "type": "string"
                  },
                  "payloadType": {
                    "example": "default",
                    "description": "Payload type to use when testing the connector.",
                    "type": "string"
