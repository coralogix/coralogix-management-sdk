{
  "openapi": "3.0.0",
  "info": {
    "title": "",
    "version": "1.0.0"
  },
  "paths": {
    "/enrichment-rules/enrichment-rules/v1": {
      "get": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Get Enrichments",
        "description": "Returns all enrichment rules for the team.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_GetEnrichments",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetEnrichmentsResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Atomic Overwrite for CustomEnrichments only",
        "description": "Updates enrichment rules.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_AtomicOverwriteEnrichments",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "description": "Request to atomically update enrichment rules.",
                "type": "object",
                "properties": {
                  "enrichmentFields": {
                    "description": "Deprecated: enrichment field definitions.",
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EnrichmentFieldDefinition"
                    }
                  },
                  "enrichmentType": {
                    "$ref": "#/components/schemas/EnrichmentType"
                  },
                  "requestEnrichments": {
                    "description": "List of enrichment rules to atomically replace existing rules.",
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EnrichmentRequestModel"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AtomicOverwriteEnrichmentsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Add Enrichments",
        "description": "Creates new enrichment rules.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_AddEnrichments",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Enrichments Creation Request",
                "description": "This response data structure represents a collection of enrichments",
                "type": "object",
                "properties": {
                  "requestEnrichments": {
                    "description": "The request enrichments.",
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EnrichmentRequestModel"
                    }
                  }
                },
                "required": [
                  "requestEnrichments"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddEnrichmentsResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Delete Enrichments",
        "description": "Deletes all enrichment rules for the team.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_RemoveEnrichments",
        "parameters": [
          {
            "in": "query",
            "name": "enrichment_ids",
            "description": "The unique identifiers of the enrichment rules to delete.",
            "schema": {
              "example": [
                1,
                2,
                3
              ],
              "description": "The unique identifiers of the enrichment rules to delete.",
              "type": "array",
              "items": {
                "description": "The unique identifiers of the enrichment rules to delete.",
                "type": "integer",
                "format": "int64"
              }
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RemoveEnrichmentsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/enrichment-rules/enrichment-rules/v1/all": {
      "put": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Atomic Overwrite for ALL types of enrichments",
        "description": "Atomic Overwrite for ALL types of enrichments. The request is the desired state which will override ALL enrichments. WARNING: This operation will delete all existing enrichments and replace them with the provided ones.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_AtomicOverwriteAllEnrichments",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "description": "Request to atomically replace all enrichment rules.",
                "type": "object",
                "properties": {
                  "requestEnrichments": {
                    "description": "Complete list of enrichment rules to replace all existing rules.",
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EnrichmentRequestModel"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AtomicOverwriteAllEnrichmentsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/enrichment-rules/enrichment-rules/v1/limit": {
      "get": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Get Enrichment Limit",
        "description": "Returns the maximum number of enrichment rules allowed.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_GetEnrichmentLimit",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetEnrichmentLimitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/enrichment-rules/enrichment-rules/v1/settings": {
      "get": {
        "tags": [
          "Enrichments Service"
        ],
        "summary": "Get Company Enrichment Settings",
        "description": "Returns the current enrichment settings for the team.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "EnrichmentService_GetCompanyEnrichmentSettings",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCompanyEnrichmentSettingsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddEnrichmentsResponse": {
        "externalDocs": {
          "description": "Find out more about enrichments",
          "url": "https://coralogix.com/docs/user-guides/data-transformation/enrichments/custom-enrichment/"
        },
        "title": "Encrichments Creation Response",
        "description": "Response data structure for enrichments creation",
        "type": "object",
        "properties": {
          "enrichments": {
            "description": "List of enrichments.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Enrichment"
            }
          }
        },
        "required": [
          "enrichments"
        ]
      },
      "AtomicOverwriteAllEnrichmentsResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response returned after atomically replacing all enrichment rules.",
        "type": "object",
        "properties": {
          "enrichments": {
            "description": "List of enrichments.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Enrichment"
            }
          }
        }
      },
      "AtomicOverwriteEnrichmentsResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response returned after atomically updating enrichment rules.",
        "type": "object",
        "properties": {
          "enrichments": {
            "description": "List of enrichments.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Enrichment"
            }
          }
        }
      },
      "AwsType": {
        "externalDocs": {
          "url": ""
        },
        "description": "Aws type.",
        "type": "object",
        "properties": {
          "resourceType": {
            "example": "ec2",
            "description": "The resource type.",
            "type": "string"
          }
        }
      },
      "CompanyEnrichmentSettings": {
        "externalDocs": {
          "url": ""
        },
        "description": "Company enrichment settings.",
        "type": "object",
        "properties": {
          "enrichmentAmountLimit": {
            "description": "The enrichment amount limit.",
            "type": "integer",
            "format": "int64"
          },
          "enrichmentsInUse": {
            "description": "The enrichments in use.",
            "type": "integer",
            "format": "int64"
          },
          "queryOnlyRowLimit": {
            "description": "The query only row limit.",
            "type": "integer",
            "format": "int64"
          },
          "queryOnlySizeLimitBytes": {
            "example": "",
            "description": "The query only size limit bytes.",
            "type": "string",
            "format": "int64"
          },
          "rowLimit": {
            "description": "The row limit.",
            "type": "integer",
            "format": "int64"
          },
          "sizeLimitBytes": {
            "example": "",
            "description": "The size limit bytes.",
            "type": "string",
            "format": "int64"
          }
        }
      },
      "CustomEnrichmentType": {
        "externalDocs": {
          "url": ""
        },
        "description": "Custom enrichment type.",
        "type": "object",
        "properties": {
          "id": {
            "example": 1,
            "description": "Unique identifier.",
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "DatasetTarget": {
        "externalDocs": {
          "url": ""
        },
        "title": "Dataset Target",
        "description": "This data structure represents a target for enrichments. It defines a dataset in which the enrichment will be applied to.",
        "type": "object",
        "properties": {
          "dataset": {
            "example": "dataset1",
            "description": "The dataset name in which the enrichment will be applied.",
            "type": "string",
            "pattern": "^[a-zA-Z0-9_][a-zA-Z0-9_./-]*$",
            "minLength": 1,
            "maxLength": 100
          }
        }
      },
      "Enrichment": {
        "externalDocs": {
          "description": "Find out more about enrichments",
          "url": "https://coralogix.com/docs/user-guides/data-transformation/enrichments/custom-enrichment/"
        },
        "title": "Enrichment",
        "description": "This data structure represents an enrichment",
        "type": "object",
        "properties": {
          "enrichedFieldName": {
            "example": "1",
            "description": "The enriched field name.",
            "type": "string"
          },
          "enrichmentType": {
            "$ref": "#/components/schemas/EnrichmentType"
          },
          "fieldName": {
            "example": "1",
            "description": "The field name.",
            "type": "string"
          },
          "id": {
            "example": 1,
            "description": "Unique identifier.",
            "type": "integer",
            "format": "int64"
          },
          "selectedColumns": {
            "example": [
              "city",
              "population"
            ],
            "description": "The selected columns.",
            "type": "array",
            "items": {
              "description": "The selected columns.",
              "type": "string"
            }
          },
          "targets": {
            "description": "The targets for the enrichment",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatasetTarget"
            },
            "minItems": 1,
            "maxItems": 10
          }
        },
        "required": [
          "id",
          "fieldName",
          "enrichmentType"
        ]
      },
      "EnrichmentFieldDefinition": {
        "type": "object",
        "properties": {
          "enrichedFieldName": {
            "description": "The enriched field name.",
            "type": "string"
          },
          "fieldName": {
            "description": "The field name.",
            "type": "string"
          },
          "selectedColumns": {
            "description": "The selected columns.",
            "type": "array",
            "items": {
              "description": "The selected columns.",
              "type": "string"
            }
          },
          "targets": {
            "description": "The targets for the enrichment",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatasetTarget"
            },
            "minItems": 1,
            "maxItems": 10
          }
        }
      },
      "EnrichmentRequestModel": {
        "externalDocs": {
          "description": "Find out more about enrichments",
          "url": "https://coralogix.com/docs/user-guides/data-transformation/enrichments/custom-enrichment/"
        },
        "title": "Enrichment Prototype",
        "description": "The enrichment request model",
        "type": "object",
        "properties": {
          "enrichedFieldName": {
            "description": "The enriched field name.",
            "type": "string"
          },
          "enrichmentType": {
            "$ref": "#/components/schemas/EnrichmentType"
          },
          "fieldName": {
            "example": "sourceIPs",
            "description": "The field name.",
            "type": "string"
          },
          "selectedColumns": {
            "description": "The selected columns.",
            "type": "array",
            "items": {
              "description": "The selected columns.",
              "type": "string"
            }
          },
          "targets": {
            "description": "The targets for the enrichment",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatasetTarget"
            },
            "minItems": 1,
            "maxItems": 10
          }
        },
        "required": [
          "fieldName",
          "enrichmentType"
        ]
      },
      "EnrichmentType": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/EnrichmentTypeAws"
          },
          {
            "$ref": "#/components/schemas/EnrichmentTypeCustomEnrichment"
          },
          {
            "$ref": "#/components/schemas/EnrichmentTypeGeoIp"
          },
          {
            "$ref": "#/components/schemas/EnrichmentTypeSuspiciousIp"
          }
        ]
      },
      "EnrichmentTypeAws": {
        "externalDocs": {
          "url": ""
        },
        "description": "Enrichment type.",
        "type": "object",
        "properties": {
          "aws": {
            "$ref": "#/components/schemas/AwsType"
          }
        },
        "required": [
          "aws"
        ]
      },
      "EnrichmentTypeCustomEnrichment": {
        "externalDocs": {
          "url": ""
        },
        "description": "Enrichment type.",
        "type": "object",
        "properties": {
          "customEnrichment": {
            "$ref": "#/components/schemas/CustomEnrichmentType"
          }
        },
        "required": [
          "customEnrichment"
        ]
      },
      "EnrichmentTypeGeoIp": {
        "externalDocs": {
          "url": ""
        },
        "description": "Enrichment type.",
        "type": "object",
        "properties": {
          "geoIp": {
            "$ref": "#/components/schemas/GeoIpType"
          }
        },
        "required": [
          "geoIp"
        ]
      },
      "EnrichmentTypeSuspiciousIp": {
        "externalDocs": {
          "url": ""
        },
        "description": "Enrichment type.",
        "type": "object",
        "properties": {
          "suspiciousIp": {
            "$ref": "#/components/schemas/SuspiciousIpType"
          }
        },
        "required": [
          "suspiciousIp"
        ]
      },
      "FilterPathAndValues": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FilterPathAndValuesFilters"
          },
          {
            "$ref": "#/components/schemas/FilterPathAndValuesMultipleValues"
          }
        ]
      },
      "FilterPathAndValuesFilters": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "path": {
            "example": "test",
            "type": "string"
          }
        },
        "required": [
          "path",
          "values",
          "filters"
        ]
      },
      "FilterPathAndValuesMultipleValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string"
          }
        },
        "required": [
          "path",
          "values",
          "multipleValues"
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            }
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
