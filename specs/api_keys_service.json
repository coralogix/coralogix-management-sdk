              "schema": {
                "description": "This data structure is used to update an API key.",
                "properties": {
                  "isActive": {
                    "example": true,
                    "type": "boolean"
                  },
                  "newName": {
                    "example": "my_new_name",
                    "type": "string"
                  },
                  "permissions": {
                    "title": "Permissions",
                    "required": [
                      "permissions"
                    ],
                    "type": "object",
                    "properties": {
                      "permissions": {
                        "type": "array",
                        "items": {
