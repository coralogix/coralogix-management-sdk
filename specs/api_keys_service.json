                            "example": true
                          },
                          "id": {
                            "type": "string"
                          },
                          "keyPermissions": {
                            "title": "Key Permissions",
                            "required": [
                              "presets",
                              "permissions"
                            ],
                            "type": "object",
                            "properties": {
                              "permissions": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "presets": {
                                "type": "array",
                                "items": {
                                  "title": "Preset Info",
                                  "required": [
                                    "name",
                                    "permissions"
                                  ],
