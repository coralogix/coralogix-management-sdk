  "components": {
    "schemas": {
      "AlertSuppressionStrategy": {
        "description": "Alert suppression strategy.",
        "type": "string",
        "enum": [
          "ALERT_SUPPRESSION_STRATEGY_UNSPECIFIED",
          "ALERT_SUPPRESSION_STRATEGY_IGNORE",
          "ALERT_SUPPRESSION_STRATEGY_CREATE_CASE"
        ]
      },
      "All": {
        "externalDocs": {
          "url": ""
        },
        "title": "All filter values selected",
        "description": "Represents selection of all items in the filter",
        "type": "object",
        "additionalProperties": false
      },
      "AutoResolveConfig": {
        "externalDocs": {
          "url": ""
        },
        "title": "Auto resolve config",
        "description": "Configuration for automatically resolving cases after a certain period of inactivity.",
        "type": "object",
        "properties": {
          "enabled": {
            "description": "Enable/disable automatic resolution",
            "type": "boolean"
          },
          "inactivePeriod": {
            "example": "3600s",
            "description": "Period of inactivity after which cases are automatically resolved.",
            "type": "string",
            "minLength": 0
          }
        }
      },
      "CaseKPIs": {
        "externalDocs": {
          "url": ""
        },
        "title": "KPI settings",
        "description": "Case lifecycle KPI thresholds grouped first by KPI type and then by case priority.",
        "type": "object",
        "properties": {
          "thresholds": {
            "description": "List of KPI thresholds for different case priorities.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KPISettings"
            },
            "minItems": 0
          }
        }
      },
      "CaseLifecycle": {
        "externalDocs": {
          "url": ""
        },
        "title": "Case lifecycle settings",
        "description": "Team-level configuration options for the lifecycle of case, such as suppression and snooze periods.",
        "type": "object",
        "properties": {
          "alertSuppressionStrategy": {
            "$ref": "#/components/schemas/AlertSuppressionStrategy"
          },
          "autoResolve": {
            "$ref": "#/components/schemas/AutoResolveConfig"
          },
          "kpi": {
            "$ref": "#/components/schemas/CaseKPIs"
          },
          "resolutionSnoozePeriod": {
            "example": "600s",
            "description": "Period after resolution during which new cases are snoozed.",
            "type": "string",
            "minLength": 0
          },
          "suppressionPeriod": {
            "example": "3600s",
            "description": "Default period during which duplicate or related cases are suppressed.",
            "type": "string",
            "minLength": 0
          }
        }
      },
      "CasePriority": {
        "description": "Case priority.",
        "type": "string",
        "enum": [
          "CASE_PRIORITY_UNSPECIFIED",
          "CASE_PRIORITY_P1",
          "CASE_PRIORITY_P2",
          "CASE_PRIORITY_P3",
          "CASE_PRIORITY_P4",
          "CASE_PRIORITY_P5"
        ]
      },
      "CaseSettings": {
        "externalDocs": {
          "url": ""
        },
        "title": "Case settings team configuration",
        "description": "Team-level configuration entity for case management.",
        "type": "object",
        "properties": {
          "caseLifecycle": {
            "$ref": "#/components/schemas/CaseLifecycle"
          },
          "createTime": {
            "example": "2025-09-22T10:30:00.000Z",
            "description": "Timestamp when the team configuration was created",
            "type": "string",
            "format": "date-time",
            "minLength": 20,
            "maxLength": 30
          },
          "globalIndicatorSettings": {
            "$ref": "#/components/schemas/GlobalIndicatorSettings"
          },
          "id": {
            "example": "3f166e9f-3c88-4af2-b52e-138f339dab3e",
            "description": "Unique identifier for the team configuration",
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
            "minLength": 36,
            "maxLength": 36
          },
          "name": {
            "example": "Default Team Config",
            "description": "Human-readable name for the team configuration",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 4096
          },
          "updateTime": {
            "description": "Timestamp when the team configuration was last updated",
            "type": "string",
            "format": "date-time",
            "minLength": 20,
            "maxLength": 30
          }
        }
      },
      "CreateCaseSettingsResponse": {
        "externalDocs": {
          "url": ""
        },
        "title": "Create case settings response",
        "description": "Response containing the newly created case settings team configuration.",
        "type": "object",
        "properties": {
          "caseSettings": {
            "$ref": "#/components/schemas/CaseSettings"
          }
        },
        "required": [
          "caseSettings"
        ]
      },
      "DeleteCaseSettingsResponse": {
        "externalDocs": {
          "url": ""
        },
        "title": "Delete case settings response",
        "description": "Empty response; success indicated by HTTP status",
        "type": "object",
        "additionalProperties": false
      },
      "EntityLabelFilter": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/EntityLabelFilterAll"
          },
          {
            "$ref": "#/components/schemas/EntityLabelFilterValuesVariant"
          }
        ]
      },
      "EntityLabelFilter.Values": {
        "externalDocs": {
          "url": ""
        },
        "description": "An explicit list of entity label key-value pairs to include in the filter.",
        "type": "object",
        "properties": {
          "items": {
            "description": "List of EntityLabels (Key/Value) to filter to. Passing empty list here means no alerts will be processed.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/v1.KeyValue"
            },
            "minItems": 0
          }
        }
      },
      "EntityLabelFilterAll": {
        "externalDocs": {
          "url": ""
        },
        "title": "All or EntityLabel list",
        "description": "Select all items from a specific list of EntityLabels (Key/Values).",
        "type": "object",
        "properties": {
          "all": {
            "$ref": "#/components/schemas/All"
          }
        },
        "required": [
          "all"
        ]
      },
      "EntityLabelFilterValuesVariant": {
        "externalDocs": {
          "url": ""
        },
        "title": "All or EntityLabel list",
        "description": "Select all items from a specific list of EntityLabels (Key/Values).",
        "type": "object",
        "properties": {
          "values": {
            "$ref": "#/components/schemas/EntityLabelFilter.Values"
          }
        },
        "required": [
          "values"
        ]
      },
      "Error": {
        "description": "Standard error response body returned for a failed request.",
        "type": "object",
        "properties": {
          "code": {
            "description": "HTTP status code of the error (for example 400, 404, 500).",
            "type": "integer",
            "format": "int32",
            "minimum": 100,
            "maximum": 599
          },
          "message": {
            "description": "Human-readable description of the error.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 0,
            "maxLength": 4096
          }
        }
      },
      "FilterPathAndValues": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FilterPathAndValuesFilters"
          },
          {
            "$ref": "#/components/schemas/FilterPathAndValuesMultipleValues"
          }
        ]
      },
      "FilterPathAndValuesFilters": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path",
          "values",
          "filters"
        ]
      },
      "FilterPathAndValuesMultipleValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path",
          "values",
          "multipleValues"
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            },
            "minItems": 0
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "GetActiveCaseSettingsResponse": {
        "externalDocs": {
          "url": ""
        },
        "title": "Get active case settings response",
        "description": "Response containing the case settings team configuration currently active for the caller.",
        "type": "object",
        "properties": {
          "caseSettings": {
            "$ref": "#/components/schemas/CaseSettings"
          }
        },
        "required": [
          "caseSettings"
        ]
      },
      "GetCaseSettingsResponse": {
        "externalDocs": {
          "url": ""
        },
        "title": "Get case settings response",
        "description": "Response containing the requested case settings team configuration.",
        "type": "object",
        "properties": {
          "caseSettings": {
            "$ref": "#/components/schemas/CaseSettings"
          }
        },
        "required": [
          "caseSettings"
        ]
      },
      "GetSystemDefaultCaseSettingsResponse": {
        "externalDocs": {
          "url": ""
        },
        "title": "Get default case settings response",
        "description": "Response containing platform-wide default case settings team configuration values.",
        "type": "object",
        "properties": {
          "caseLifecycle": {
            "$ref": "#/components/schemas/CaseLifecycle"
          },
          "globalIndicatorSettings": {
            "$ref": "#/components/schemas/GlobalIndicatorSettings"
          }
        },
        "required": [
          "globalIndicatorSettings"
        ]
      },
      "GlobalIndicatorSettings": {
        "externalDocs": {
          "url": ""
        },
        "title": "Global indicator settings",
        "description": "Team-level indicator configuration options for case management, including case lifecycle and event filtering conditions.",
