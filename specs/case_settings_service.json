                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Active team config not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
