  "paths": {
    "/cases/cases/case-settings/v1/configs": {
      "post": {
        "tags": [
          "Case Settings service"
        ],
        "summary": "Create a case settings team configuration",
        "description": "Create a new case settings team configuration with an optional display name and settings.\n\nRequires the following permissions:\n- `case-config:Update`",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CaseSettingsService_CreateCaseSettings",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Create case settings request",
                "description": "Request to create a new case settings team configuration.",
                "type": "object",
                "properties": {
                  "caseLifecycle": {
                    "$ref": "#/components/schemas/CaseLifecycle"
                  },
                  "globalIndicatorSettings": {
                    "$ref": "#/components/schemas/GlobalIndicatorSettings"
                  },
                  "name": {
                    "example": "Primary Case Settings",
                    "description": "Optional display name for the case settings team configuration",
                    "type": "string",
                    "pattern": "^[\\s\\S]*$",
                    "minLength": 1,
                    "maxLength": 4096
                  }
                },
                "required": [
                  "globalIndicatorSettings"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCaseSettingsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-coralogixPermissions": [
          "case-config:Update"
        ]
      }
    },
    "/cases/cases/case-settings/v1/configs/{id}": {
      "get": {
        "tags": [
          "Case Settings service"
        ],
        "summary": "Get a case settings team configuration",
        "description": "Retrieve a single case settings team configuration by its identifier.\n\nRequires the following permissions:\n- `case-config:Read`",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CaseSettingsService_GetCaseSettings",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "ID of the case settings team configuration",
            "required": true,
            "schema": {
              "example": "8c0c02a3-3c1c-4d56-9a2d-9f6ab6a4b321",
              "description": "ID of the case settings team configuration",
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
              "minLength": 36,
              "maxLength": 36
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCaseSettingsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Case settings not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-coralogixPermissions": [
          "case-config:Read"
        ]
      },
      "delete": {
        "tags": [
          "Case Settings service"
        ],
        "summary": "Delete a case settings team configuration",
        "description": "Delete a case settings team configuration by its identifier.\n\nRequires the following permissions:\n- `case-config:Update`",
        "externalDocs": {
          "url": ""
