              "example": "8c0c02a3-3c1c-4d56-9a2d-9f6ab6a4b321",
              "description": "ID of the case settings team configuration to delete",
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
              "minLength": 36,
              "maxLength": 36
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteCaseSettingsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Case settings not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-coralogixPermissions": [
          "case-config:Update"
        ]
      },
      "patch": {
        "tags": [
          "Case Settings service"
        ],
        "summary": "Update a case settings team configuration",
        "description": "Update the display name and/or settings of an existing case settings team configuration.\n\nRequires the following permissions:\n- `case-config:Update`",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CaseSettingsService_UpdateCaseSettings",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "ID of the case settings team configuration to update",
            "required": true,
            "schema": {
              "example": "8c0c02a3-3c1c-4d56-9a2d-9f6ab6a4b321",
              "description": "ID of the case settings team configuration to update",
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
              "minLength": 36,
              "maxLength": 36
            },
            "style": "simple"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Update case settings request",
                "description": "Request to update an existing case settings team configuration.",
                "type": "object",
                "properties": {
                  "caseLifecycle": {
                    "$ref": "#/components/schemas/CaseLifecycle"
                  },
                  "globalIndicatorSettings": {
                    "$ref": "#/components/schemas/GlobalIndicatorSettings"
                  },
                  "name": {
                    "example": "SRE Case Settings",
                    "description": "New display name for the case settings team configuration",
                    "type": "string",
                    "pattern": "^[\\s\\S]*$",
                    "minLength": 1,
                    "maxLength": 4096
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateCaseSettingsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Case settings not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-coralogixPermissions": [
          "case-config:Update"
        ]
      }
    },
    "/cases/cases/case-settings/v1/configs:getActive": {
