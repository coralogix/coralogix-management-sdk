  "paths": {
    "/notifications/notification-center/v1/routers": {
      "get": {
        "tags": [
          "Global routers service"
        ],
        "summary": "List Global Routers",
        "description": "Returns all notification routers for the team.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_ListGlobalRouters",
        "parameters": [
          {
            "in": "query",
            "name": "entity_type",
            "description": "Deprecated. Filter routers by entity type.",
            "schema": {
              "$ref": "#/components/schemas/notification_center.EntityType"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "source_entity_labels",
            "description": "Filter routers by source entity labels. Each entry restricts results to routers whose source entity has the matching label values. If empty, all routers are returned.",
            "schema": {
              "description": "Filter routers by source entity labels. Each entry restricts results to routers whose source entity has the matching label values. If empty, all routers are returned.",
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "values": {
                    "description": "The values.",
                    "type": "array",
                    "items": {
                      "description": "The values.",
                      "type": "string",
                      "minLength": 0
                    },
                    "minItems": 1,
                    "maxItems": 100
                  }
                }
              }
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListGlobalRoutersResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Global routers service"
        ],
        "summary": "Replace Global Router",
        "description": "Updates an existing notification router.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_ReplaceGlobalRouter",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Replace Global Router Request",
                "description": "Request which updates an existing global router",
                "type": "object",
                "properties": {
                  "router": {
                    "$ref": "#/components/schemas/GlobalRouter"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReplaceGlobalRouterResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Global routers service"
        ],
        "summary": "Create Global Router",
        "description": "Creates a new notification router.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_CreateGlobalRouter",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Create Global Router Request",
                "description": "Request to create a global router",
                "type": "object",
                "properties": {
                  "router": {
                    "$ref": "#/components/schemas/GlobalRouter"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateGlobalRouterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/notifications/notification-center/v1/routers/all/summaries": {
      "get": {
        "tags": [
          "Global routers service"
        ],
        "summary": "Batch Get Global Routers",
        "description": "Returns summary information for all notification routers.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_BatchGetGlobalRouters",
        "parameters": [
          {
            "in": "query",
            "name": "global_router_ids",
            "description": "The unique identifiers of the global routers to retrieve summaries for.",
            "schema": {
              "description": "The unique identifiers of the global routers to retrieve summaries for.",
              "type": "array",
              "items": {
                "description": "The unique identifiers of the global routers to retrieve summaries for.",
                "type": "string",
                "minLength": 0
              },
              "minItems": 0,
              "maxItems": 200
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchGetGlobalRoutersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/notifications/notification-center/v1/routers/matcher/validate": {
      "post": {
        "tags": [
          "Global routers service"
        ],
        "summary": "Validate Entity Label Matcher",
        "description": "Validates a notification router matcher configuration.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_ValidateEntityLabelMatcher",
        "parameters": [
          {
            "in": "query",
            "name": "entity_label_matcher",
            "description": "Entity label matcher to validate, expressed as a map of label keys to expected values.",
            "schema": {
              "description": "Entity label matcher to validate, expressed as a map of label keys to expected values.",
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "minLength": 0
              }
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateEntityLabelMatcherResponse"
                }
              }
            }
          }
        }
      }
    },
    "/notifications/notification-center/v1/routers/{id}": {
      "get": {
        "tags": [
          "Global routers service"
        ],
        "summary": "Get Global Router",
        "description": "Returns the details of the specified notification router.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_GetGlobalRouter",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "The unique identifier of the global router to retrieve.",
            "required": true,
            "schema": {
              "description": "The unique identifier of the global router to retrieve.",
              "type": "string",
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
              "minLength": 1,
              "maxLength": 128
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetGlobalRouterResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Global routers service"
        ],
        "summary": "Delete Global Router",
        "description": "Deletes the notification router with the specified ID.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "GlobalRoutersService_DeleteGlobalRouter",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "Unique identifier.",
            "required": true,
            "schema": {
              "description": "Unique identifier.",
              "type": "string",
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
              "minLength": 1,
              "maxLength": 128
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteGlobalRouterResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BatchGetGlobalRoutersResponse": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Batch Get Global Routers Response",
        "description": "Response containing requested global routers and missing global routers ids",
        "type": "object",
        "properties": {
          "notFoundIds": {
            "example": [
              "global-router-id-3"
            ],
            "description": "The not found ids.",
            "type": "array",
            "items": {
              "description": "The not found ids.",
              "type": "string",
              "minLength": 0
            },
            "minItems": 0,
            "maxItems": 200
          },
          "routers": {
            "description": "The routers.",
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/GlobalRouter"
            }
          }
        }
      },
      "CreateGlobalRouterResponse": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Create Global Router Response",
        "description": "Response which contains a created global router",
        "type": "object",
        "properties": {
          "router": {
            "$ref": "#/components/schemas/GlobalRouter"
          }
        }
      },
      "DeleteGlobalRouterResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response returned after successfully deleting a notification router.",
        "type": "object",
        "additionalProperties": false
      },
      "FallbackTarget": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "FallbackTarget",
        "description": "Defines fallback target for notifications not matching any routing rule",
        "type": "object",
        "properties": {
          "entityType": {
            "$ref": "#/components/schemas/notification_center.EntityType"
          },
          "target": {
            "$ref": "#/components/schemas/RoutingTarget"
          }
        }
      },
      "FilterPathAndValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path"
        ],
        "oneOf": [
          {
            "type": "object",
            "required": [
              "multipleValues"
            ]
          },
          {
            "type": "object",
            "required": [
              "filters"
            ]
          }
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            },
            "minItems": 0
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "GetGlobalRouterResponse": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Get Global Router Response",
        "description": "Response containing a requested global router",
        "type": "object",
        "properties": {
          "router": {
            "$ref": "#/components/schemas/GlobalRouter"
          }
        }
      },
      "GlobalRouter": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Global Router",
        "description": "Defines a set of pre-configured routing rules for directing notifications",
        "type": "object",
        "properties": {
          "createTime": {
            "description": "The create time.",
            "type": "string",
            "format": "date-time",
            "minLength": 0
          },
          "description": {
            "description": "Human-readable description.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 0,
            "maxLength": 5000
          },
          "disabled": {
            "description": "The disabled.",
            "type": "boolean"
          },
          "entityLabels": {
            "description": "The entity labels.",
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 0
            }
          },
          "entityType": {
            "$ref": "#/components/schemas/notification_center.EntityType"
          },
          "fallback": {
            "description": "The fallback destinations to be used if no rule matches.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoutingTarget"
            },
            "minItems": 0,
            "maxItems": 10
          },
          "fallbackTargets": {
            "description": "The fallback targets.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FallbackTarget"
            },
            "minItems": 0,
            "maxItems": 10
          },
          "id": {
            "example": "a16e24c8-4db2-4abf-ba3c-c9e1fc35a3b9",
            "description": "Unique identifier.",
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
            "minLength": 1,
            "maxLength": 128
          },
          "name": {
            "example": "My Router",
            "description": "Display name.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 200
          },
          "routingLabels": {
            "$ref": "#/components/schemas/RoutingLabels"
          },
          "rules": {
            "description": "List of rules.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoutingRule"
            },
            "minItems": 0,
            "maxItems": 10
          },
          "updateTime": {
            "description": "Timestamp of the last update.",
            "type": "string",
            "format": "date-time",
            "minLength": 0
          }
        }
      },
      "ListGlobalRoutersResponse": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "List Global Routers Response",
        "description": "Response containing requested global routers",
        "type": "object",
        "properties": {
          "routers": {
            "description": "The routers.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GlobalRouter"
            },
            "minItems": 0,
            "maxItems": 200
          }
        }
      },
      "MultipleValues": {
        "type": "object",
        "properties": {
          "matcher": {
            "$ref": "#/components/schemas/events.v3.FilterMatcher"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 0
            },
            "minItems": 0
          }
        }
      },
      "ReplaceGlobalRouterResponse": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Replace Global Router Response",
        "description": "Response which contains an updated global router",
        "type": "object",
        "properties": {
          "router": {
            "$ref": "#/components/schemas/GlobalRouter"
          }
        }
      },
      "RoutingLabels": {
        "externalDocs": {
          "description": "Find out more how label based routers work",
          "url": "https://coralogix.com/docs/user-guides/notification-center/routing/introduction/#how-label-based-routers-work"
        },
        "title": "Routing Labels",
        "description": "Allows to configure routing labels which are used for routers resolution",
        "type": "object",
        "properties": {
          "environment": {
            "description": "The environment.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 256
          },
          "service": {
            "description": "Service name.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 256
          },
          "team": {
            "description": "Team.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "RoutingRule": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Routing Rule",
        "description": "Defines routing rule for notifications",
        "type": "object",
        "properties": {
          "condition": {
            "example": "alertDef.priority == 'P3'",
            "description": "Condition.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 20000
          },
          "customDetails": {
            "description": "The custom details.",
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 0
            }
          },
          "entityType": {
            "$ref": "#/components/schemas/notification_center.EntityType"
          },
          "name": {
            "description": "Display name.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 200
          },
          "targets": {
            "description": "List of targets.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoutingTarget"
            },
            "minItems": 0,
            "maxItems": 10
          }
        }
      },
      "RoutingTarget": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Routing Target",
        "description": "Defines routing target for notifications",
        "type": "object",
        "properties": {
          "connectorId": {
            "description": "The connector id.",
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
            "minLength": 1,
            "maxLength": 128
          },
          "customDetails": {
            "description": "The custom details.",
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 0
            }
          },
          "id": {
            "example": "d4b56246-64bb-4714-a8bd-97c999f1d801",
            "description": "Unique identifier.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 36,
            "maxLength": 36
          },
          "presetId": {
            "description": "The preset id.",
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$",
            "minLength": 1,
            "maxLength": 128
          }
        }
      },
      "ValidateEntityLabelMatcherResponse": {
        "externalDocs": {
          "description": "Find out more about notification center",
          "url": "https://coralogix.com/docs/user-guides/notification-center/introduction/welcome/"
        },
        "title": "Validate Entity Label Matcher Response",
        "description": "Response which contains whether the given entity label matcher is valid",
        "type": "object",
        "properties": {
          "result": {
            "$ref": "#/components/schemas/ValidateEntityLabelMatcherResult"
          }
        }
      },
      "ValidateEntityLabelMatcherResult": {
        "externalDocs": {
          "url": ""
        },
        "description": "Result of validating an entity label matcher, indicating whether it is valid or contains errors.",
        "type": "object",
        "properties": {
          "failure": {
            "$ref": "#/components/schemas/ValidateEntityLabelMatcherResult.Failure"
          },
          "success": {
            "$ref": "#/components/schemas/ValidateEntityLabelMatcherResult.Success"
          }
        },
        "oneOf": [
          {
            "type": "object",
            "required": [
              "success"
            ]
          },
          {
            "type": "object",
            "required": [
              "failure"
            ]
          },
          {
            "type": "object",
            "not": {
              "anyOf": [
                {
                  "type": "object",
                  "required": [
                    "success"
                  ]
                },
                {
                  "type": "object",
                  "required": [
                    "failure"
                  ]
                }
              ]
            }
          }
        ]
      },
      "ValidateEntityLabelMatcherResult.Failure": {
        "externalDocs": {
          "url": ""
        },
        "description": "Test outgoing webhook response.failure.",
        "type": "object",
        "properties": {
          "message": {
            "description": "Human-readable message.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 1,
            "maxLength": 10000
          }
        }
      },
      "ValidateEntityLabelMatcherResult.Success": {
        "externalDocs": {
          "url": ""
        },
        "description": "Test integration result.success.",
        "type": "object",
        "additionalProperties": false
      },
      "events.v3.FilterMatcher": {
        "type": "string",
        "enum": [
          "FILTER_MATCHER_TEXT_OR_UNSPECIFIED",
          "FILTER_MATCHER_REGEXP"
        ]
      },
      "notification_center.EntityType": {
        "description": "Entity type.",
        "type": "string",
        "enum": [
          "ENTITY_TYPE_UNSPECIFIED",
          "ALERTS",
          "TEST_NOTIFICATIONS",
          "CASES"
        ]
      },
      "v3.FilterOperator": {
        "description": "Filter operator.",
        "type": "string",
        "enum": [
          "FILTER_OPERATOR_AND_OR_UNSPECIFIED",
          "FILTER_OPERATOR_OR"
        ]
      }
    }
  }
}