{
  "openapi": "3.0.0",
  "info": {
    "title": "",
    "version": "1.0.0"
  },
  "paths": {
    "/data-exploration/views/v1/views": {
      "get": {
        "tags": [
          "Views service"
        ],
        "summary": "List views service",
        "description": "Lists all company public views",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ViewsService_ListViews",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListViewsResponse"
                },
                "example": {
                  "views": [
                    {
                      "filters": {
                        "filters": [
                          {
                            "name": "applicationName",
                            "selectedValues": {
                              "demo": true
                            }
                          },
                          {
                            "name": "subsystemName",
                            "selectedValues": {
                              "demo": true
                            }
                          },
                          {
                            "name": "operationName",
                            "selectedValues": {
                              "demo": true
                            }
                          },
                          {
                            "name": "serviceName",
                            "selectedValues": {
                              "demo": true
                            }
                          },
                          {
                            "name": "severity",
                            "selectedValues": {
                              "demo": true
                            }
                          }
                        ]
                      },
                      "id": 52,
                      "name": "Logs view",
                      "searchQuery": {
                        "query": "logs"
                      },
                      "timeSelection": {
                        "customSelection": {
                          "fromTime": "2024-01-25T11:31:43.152Z",
                          "toTime": "2024-01-25T11:37:13.238Z"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Views service"
        ],
        "summary": "Create a view service",
        "description": "Creates a new view",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ViewsService_CreateView",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "ViewFolder",
                "description": "View folder.",
                "type": "object",
                "properties": {
                  "filters": {
                    "$ref": "#/components/schemas/SelectedFilters"
                  },
                  "folderId": {
                    "example": "3dc02998-0b50-4ea8-b68a-4779d716fa1f",
                    "description": "Unique identifier for folders",
                    "type": "string",
                    "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
                    "minLength": 36,
                    "maxLength": 36
                  },
                  "name": {
                    "example": "Logs view",
                    "description": "View name",
                    "type": "string",
                    "minLength": 1
                  },
                  "searchQuery": {
                    "$ref": "#/components/schemas/SearchQuery"
                  },
                  "timeSelection": {
                    "$ref": "#/components/schemas/TimeSelection"
                  },
                  "viewType": {
                    "$ref": "#/components/schemas/ViewType"
                  }
                },
                "required": [
                  "name",
                  "timeSelection"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/View"
                },
                "example": {
                  "filters": {
                    "filters": [
                      {
                        "name": "applicationName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "subsystemName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "operationName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "serviceName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "severity",
                        "selectedValues": {
                          "demo": true
                        }
                      }
                    ]
                  },
                  "id": 52,
                  "name": "Logs view",
                  "searchQuery": {
                    "query": "logs"
                  },
                  "timeSelection": {
                    "customSelection": {
                      "fromTime": "2024-01-25T11:31:43.152Z",
                      "toTime": "2024-01-25T11:37:13.238Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/data-exploration/views/v1/views/{id}": {
      "get": {
        "tags": [
          "Views service"
        ],
        "summary": "Get view service",
        "description": "Gets a view by ID",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ViewsService_GetView",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/View"
                },
                "example": {
                  "filters": {
                    "filters": [
                      {
                        "name": "applicationName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "subsystemName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "operationName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "serviceName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "severity",
                        "selectedValues": {
                          "demo": true
                        }
                      }
                    ]
                  },
                  "id": 52,
                  "name": "Logs view",
                  "searchQuery": {
                    "query": "logs"
                  },
                  "timeSelection": {
                    "customSelection": {
                      "fromTime": "2024-01-25T11:31:43.152Z",
                      "toTime": "2024-01-25T11:37:13.238Z"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Views service"
        ],
        "summary": "Replace a view service",
        "description": "Replaces an existing view",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ViewsService_ReplaceView",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "View",
                "description": "Response for views.",
                "type": "object",
                "properties": {
                  "filters": {
                    "$ref": "#/components/schemas/SelectedFilters"
                  },
                  "folderId": {
                    "example": "3dc02998-0b50-4ea8-b68a-4779d716fa1f",
                    "description": "Unique identifier for folders",
                    "type": "string",
                    "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
                    "minLength": 36,
                    "maxLength": 36
                  },
                  "isCompactMode": {
                    "description": "The is compact mode.",
                    "type": "boolean"
                  },
                  "name": {
                    "example": "Logs view",
                    "description": "View name",
                    "type": "string",
                    "minLength": 1
                  },
                  "searchQuery": {
                    "$ref": "#/components/schemas/SearchQuery"
                  },
                  "timeSelection": {
                    "$ref": "#/components/schemas/TimeSelection"
                  },
                  "viewType": {
                    "$ref": "#/components/schemas/ViewType"
                  }
                },
                "required": [
                  "name",
                  "timeSelection"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/View"
                },
                "example": {
                  "filters": {
                    "filters": [
                      {
                        "name": "applicationName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "subsystemName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "operationName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "serviceName",
                        "selectedValues": {
                          "demo": true
                        }
                      },
                      {
                        "name": "severity",
                        "selectedValues": {
                          "demo": true
                        }
                      }
                    ]
                  },
                  "id": 52,
                  "name": "Logs view",
                  "searchQuery": {
                    "query": "logs new"
                  },
                  "timeSelection": {
                    "customSelection": {
                      "fromTime": "2024-01-25T11:31:43.152Z",
                      "toTime": "2024-01-25T11:37:13.238Z"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Views service"
        ],
        "summary": "Delete view service",
        "description": "Deletes a view by ID",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ViewsService_DeleteView",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteViewResponse"
                }
              }
            }
          }
        }
      },
      "parameters": [
        {
          "in": "path",
          "name": "id",
          "description": "id",
          "required": true,
          "schema": {
            "example": 52,
            "description": "id",
            "type": "integer",
            "format": "int32"
          },
          "style": "simple"
        }
      ]
    }
  },
  "components": {
    "schemas": {
      "CustomTimeSelection": {
        "externalDocs": {
          "url": ""
        },
        "description": "Custom time selection.",
        "type": "object",
        "properties": {
          "fromTime": {
            "example": "2024-01-25T11:31:43.152Z",
            "description": "The from time.",
            "type": "string",
            "format": "date-time",
            "minLength": 1
          },
          "toTime": {
            "example": "2024-01-25T11:35:43.152Z",
            "description": "The to time.",
            "type": "string",
            "format": "date-time",
            "minLength": 1
          }
        },
        "required": [
          "fromTime",
          "toTime"
        ]
      },
      "DeleteViewResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response returned after successfully deleting a view.",
        "type": "object",
        "additionalProperties": false
      },
      "FilterPathAndValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path"
        ],
        "oneOf": [
          {
            "type": "object",
            "required": [
              "multipleValues"
            ]
          },
          {
            "type": "object",
            "required": [
              "filters"
            ]
          }
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            },
            "minItems": 0
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "ListViewsResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response containing a list of views.",
        "type": "object",
        "properties": {
          "views": {
            "description": "The views.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/View"
            },
            "minItems": 0
          }
        }
      },
      "MultipleValues": {
        "type": "object",
        "properties": {
          "matcher": {
            "$ref": "#/components/schemas/events.v3.FilterMatcher"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 0
            },
            "minItems": 0
          }
        }
      },
      "QuickTimeSelection": {
        "externalDocs": {
          "url": ""
        },
        "description": "Quick time selection.",
        "type": "object",
        "properties": {
          "caption": {
            "deprecated": true,
            "example": "Last Hour",
            "description": "Folder name",
            "type": "string",
            "minLength": 1
          },
          "seconds": {
            "example": 3600,
            "description": "Folder name",
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        },
        "required": [
          "seconds"
        ]
      },
      "SearchQuery": {
        "externalDocs": {
          "url": ""
        },
        "title": "SearchQuery",
        "description": "Search query.",
        "type": "object",
        "properties": {
          "query": {
            "description": "Query string.",
            "type": "string",
            "minLength": 1
          },
          "syntaxType": {
            "$ref": "#/components/schemas/SyntaxType"
          }
        },
        "required": [
          "query"
        ]
      },
      "SelectedFilters": {
        "externalDocs": {
          "url": ""
        },
        "description": "Selected filters.",
        "type": "object",
        "properties": {
          "filters": {
            "description": "List of filters.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/views.v1.Filter"
            },
            "minItems": 1
          }
        }
      },
      "SyntaxType": {
        "description": "Syntax type.",
        "type": "string",
        "enum": [
          "SYNTAX_TYPE_UNSPECIFIED",
          "SYNTAX_TYPE_LUCENE",
          "SYNTAX_TYPE_DATAPRIME"
        ]
      },
      "TimeSelection": {
        "externalDocs": {
          "url": ""
        },
        "description": "Time selection.",
        "type": "object",
        "properties": {
          "customSelection": {
            "$ref": "#/components/schemas/CustomTimeSelection"
          },
          "quickSelection": {
            "$ref": "#/components/schemas/QuickTimeSelection"
          }
        },
        "oneOf": [
          {
            "type": "object",
            "required": [
              "quickSelection"
            ]
          },
          {
            "type": "object",
            "required": [
              "customSelection"
            ]
          },
          {
            "type": "object",
            "not": {
              "anyOf": [
                {
                  "type": "object",
                  "required": [
                    "quickSelection"
                  ]
                },
                {
                  "type": "object",
                  "required": [
                    "customSelection"
                  ]
                }
              ]
            }
          }
        ]
      },
      "View": {
        "externalDocs": {
          "url": ""
        },
        "title": "View",
        "description": "Response for views.",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/SelectedFilters"
          },
          "folderId": {
            "example": "3dc02998-0b50-4ea8-b68a-4779d716fa1f",
            "description": "Unique identifier for folders",
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
            "minLength": 36,
            "maxLength": 36
          },
          "id": {
            "example": 52,
            "description": "id",
            "type": "integer",
            "format": "int32"
          },
          "isCompactMode": {
            "description": "The is compact mode.",
            "type": "boolean"
          },
          "name": {
            "example": "Logs view",
            "description": "View name",
            "type": "string",
            "minLength": 1
          },
          "searchQuery": {
            "$ref": "#/components/schemas/SearchQuery"
          },
          "timeSelection": {
            "$ref": "#/components/schemas/TimeSelection"
          },
          "viewType": {
            "$ref": "#/components/schemas/ViewType"
          }
        },
        "required": [
          "name",
          "id",
          "timeSelection"
        ]
      },
      "ViewType": {
        "description": "View type.",
        "type": "string",
        "enum": [
          "VIEW_TYPE_UNSPECIFIED",
          "VIEW_TYPE_LOGS",
          "VIEW_TYPE_TEMPLATES",
          "VIEW_TYPE_ARCHIVE_LOGS",
          "VIEW_TYPE_ARCHIVE_TEMPLATES"
        ]
      },
      "events.v3.FilterMatcher": {
        "type": "string",
        "enum": [
          "FILTER_MATCHER_TEXT_OR_UNSPECIFIED",
          "FILTER_MATCHER_REGEXP"
        ]
      },
      "v3.FilterOperator": {
        "description": "Filter operator.",
        "type": "string",
        "enum": [
          "FILTER_OPERATOR_AND_OR_UNSPECIFIED",
          "FILTER_OPERATOR_OR"
        ]
      },
      "views.v1.Filter": {
        "externalDocs": {
          "url": ""
        },
        "title": "ViewFolder",
        "description": "View folder.",
        "type": "object",
        "properties": {
          "name": {
            "example": "applicationName",
            "description": "Filter name",
            "type": "string",
            "minLength": 1
          },
          "selectedValues": {
            "description": "Filter selected values",
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          }
        },
        "required": [
          "name",
          "selectedValues"
        ]
      }
    }
  }
}