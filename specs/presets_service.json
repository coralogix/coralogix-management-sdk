        "oneOf": [
          {
            "$ref": "#/components/schemas/NotificationCenterConditionTypeMatchEntityType"
          },
          {
            "$ref": "#/components/schemas/NotificationCenterConditionTypeMatchEntityTypeAndSubType"
          }
        ]
      },
