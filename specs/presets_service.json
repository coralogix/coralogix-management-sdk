        "description": "Provides a concise overview of a preset",
        "type": "object",
        "properties": {
          "attachmentConfig": {
            "$ref": "#/components/schemas/AttachmentConfig"
          },
          "connectorType": {
            "$ref": "#/components/schemas/notification_center.ConnectorType"
