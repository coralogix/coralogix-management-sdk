        "description": "Connector type.",
        "type": "string",
        "enum": [
          "CONNECTOR_TYPE_UNSPECIFIED",
          "SLACK",
          "GENERIC_HTTPS",
          "PAGERDUTY",
          "IBM_EVENT_NOTIFICATIONS",
          "SERVICE_NOW",
          "EMAIL",
          "PAGERDUTY_INCIDENTS"
        ]
      },
