{
  "openapi": "3.0.0",
  "info": {
    "title": "",
    "version": "1.0.0"
  },
  "paths": {
    "/cases/notifications/v1/deliveries": {
      "post": {
        "tags": [
          "Cases notification service"
        ],
        "summary": "List notification deliveries for cases",
        "description": "Retrieve notification delivery records for one or more cases, including routing, target, and outcome information.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CasesNotificationService_ListNotificationDeliveries",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "List notification deliveries request",
                "type": "object",
                "properties": {
                  "caseIds": {
                    "example": [
                      "3f166e9f-3c88-4af2-b52e-138f339dab3e",
                      "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
                    ],
                    "type": "array",
                    "items": {
                      "description": "Case IDs to retrieve notification deliveries for",
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "caseIds"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListNotificationDeliveriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {}
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {}
            }
          }
        },
        "x-coralogixPermissions": [
          "case:Read"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CaseNotificationDeliveries": {
        "externalDocs": {
          "url": ""
        },
        "title": "Case notification deliveries",
        "description": "Notification deliveries for a single case.",
        "type": "object",
        "properties": {
          "notificationDeliveries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationDelivery"
            }
          }
        },
        "required": [
          "notificationDeliveries"
        ]
      },
      "ConnectorDetails": {
        "externalDocs": {
          "url": ""
        },
        "title": "Connector details",
        "description": "Details of a notification connector.",
        "type": "object",
        "properties": {
          "connectorId": {
            "example": "c1d2e3f4-5678-90ab-cdef-1234567890ab",
            "description": "Unique identifier of the connector",
            "type": "string"
          },
          "connectorName": {
            "example": "Production Slack",
            "description": "Display name of the connector",
            "type": "string"
          },
          "connectorType": {
            "$ref": "#/components/schemas/v1.ConnectorType"
          }
        },
        "required": [
          "connectorId",
          "connectorType",
          "connectorName"
        ]
      },
      "DeliveryAttempt": {
        "externalDocs": {
          "url": ""
        },
        "title": "Delivery attempt",
        "description": "A single delivery attempt to a specific connector.",
        "type": "object",
        "properties": {
          "connector": {
            "$ref": "#/components/schemas/ConnectorDetails"
          },
          "outcome": {
            "$ref": "#/components/schemas/DeliveryOutcome"
          }
        },
        "required": [
          "connector",
          "outcome"
        ]
      },
      "DeliveryFailure": {
        "externalDocs": {
          "url": ""
        },
        "title": "Delivery failure",
        "description": "Failed delivery outcome with error details.",
        "type": "object",
        "properties": {
          "errorMessage": {
            "example": "Connection timeout after 30s",
            "description": "Error message describing the failure",
            "type": "string"
          }
        },
        "required": [
          "errorMessage"
        ]
      },
      "DeliveryOutcome": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/DeliveryOutcomeSuccess"
          },
          {
            "$ref": "#/components/schemas/DeliveryOutcomeFailure"
          }
        ]
      },
      "DeliveryOutcomeFailure": {
        "externalDocs": {
          "url": ""
        },
        "title": "Delivery outcome",
        "description": "Outcome of a notification delivery attempt.",
        "type": "object",
        "properties": {
          "failure": {
            "$ref": "#/components/schemas/DeliveryFailure"
          }
        },
        "required": [
          "failure"
        ]
      },
      "DeliveryOutcomeSuccess": {
        "externalDocs": {
          "url": ""
        },
        "title": "Delivery outcome",
        "description": "Outcome of a notification delivery attempt.",
        "type": "object",
        "properties": {
          "success": {
            "$ref": "#/components/schemas/DeliverySuccess"
          }
        },
        "required": [
          "success"
        ]
      },
      "DeliverySuccess": {
        "externalDocs": {
          "url": ""
        },
        "title": "Delivery success",
        "description": "Successful delivery outcome with an optional evidence URL.",
        "type": "object",
        "properties": {
          "evidenceUrl": {
            "example": "https://workspace.slack.com/archives/C01ABC23DEF/p1234567890123456",
            "description": "URL to the delivered notification, if available (e.g. Slack message, ServiceNow record)",
            "type": "string"
          }
        }
      },
      "FieldGroup": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "FilterPathAndValues": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FilterPathAndValuesMultipleValues"
          },
          {
            "$ref": "#/components/schemas/FilterPathAndValuesFilters"
          }
        ]
      },
      "FilterPathAndValuesFilters": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "path": {
            "example": "test",
            "type": "string"
          }
        },
        "required": [
          "path",
          "values",
          "filters"
        ]
      },
      "FilterPathAndValuesMultipleValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string"
          }
        },
        "required": [
          "path",
          "values",
          "multipleValues"
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            }
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "ListNotificationDeliveriesResponse": {
        "externalDocs": {
          "url": ""
        },
        "title": "List notification deliveries response",
        "type": "object",
        "properties": {
          "deliveriesByCase": {
            "description": "Notification deliveries keyed by case ID",
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/CaseNotificationDeliveries"
            }
          }
        },
        "required": [
          "deliveriesByCase"
        ]
      },
      "MultipleValues": {
        "type": "object",
        "properties": {
          "matcher": {
            "$ref": "#/components/schemas/events.v3.FilterMatcher"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "NoNotificationCreatedResult": {
        "externalDocs": {
          "url": ""
        },
        "title": "No notification created result",
        "description": "Indicates that routers matched but no notification was ultimately created.",
        "type": "object",
        "properties": {
          "matchedRouters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RouterInfo"
            }
          }
        },
        "required": [
          "matchedRouters"
        ]
      },
      "NoRouterMatchedResult": {
        "externalDocs": {
          "url": ""
        },
        "title": "No router matched result",
        "description": "Indicates that no router matched the notification request.",
        "type": "object"
      },
      "NotificationDelivery": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/NotificationDeliveryNoRouterMatched"
          },
          {
            "$ref": "#/components/schemas/NotificationDeliveryNoNotificationCreated"
          },
          {
            "$ref": "#/components/schemas/NotificationDeliveryAttempted"
          }
        ]
      },
      "NotificationDeliveryAttempted": {
        "externalDocs": {
          "url": ""
        },
        "title": "Notification delivery",
        "description": "Delivery results for a single notification.",
        "type": "object",
        "properties": {
          "attempted": {
            "$ref": "#/components/schemas/RoutedDelivery"
          },
          "requestNotificationId": {
            "example": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
            "description": "The notification request ID that triggered this delivery, used to correlate delivery outcomes with their originating requests",
            "type": "string"
          },
          "timestamp": {
            "example": "2025-09-22T10:30:00Z",
            "description": "When the notification was triggered",
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "timestamp",
          "attempted"
        ]
      },
      "NotificationDeliveryNoNotificationCreated": {
        "externalDocs": {
          "url": ""
        },
        "title": "Notification delivery",
        "description": "Delivery results for a single notification.",
        "type": "object",
        "properties": {
          "noNotificationCreated": {
            "$ref": "#/components/schemas/NoNotificationCreatedResult"
          },
          "requestNotificationId": {
            "example": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
            "description": "The notification request ID that triggered this delivery, used to correlate delivery outcomes with their originating requests",
            "type": "string"
          },
          "timestamp": {
            "example": "2025-09-22T10:30:00Z",
            "description": "When the notification was triggered",
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "timestamp",
          "noNotificationCreated"
        ]
      },
      "NotificationDeliveryNoRouterMatched": {
        "externalDocs": {
          "url": ""
        },
        "title": "Notification delivery",
        "description": "Delivery results for a single notification.",
        "type": "object",
        "properties": {
          "noRouterMatched": {
            "$ref": "#/components/schemas/NoRouterMatchedResult"
          },
          "requestNotificationId": {
            "example": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
            "description": "The notification request ID that triggered this delivery, used to correlate delivery outcomes with their originating requests",
            "type": "string"
          },
          "timestamp": {
            "example": "2025-09-22T10:30:00Z",
            "description": "When the notification was triggered",
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "timestamp",
          "noRouterMatched"
        ]
      },
      "RoutedDelivery": {
        "externalDocs": {
          "url": ""
        },
        "title": "Routed delivery",
        "description": "Delivery attempts routed through a single router to one or more connectors.",
        "type": "object",
        "properties": {
          "attempts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeliveryAttempt"
            }
          },
          "router": {
            "$ref": "#/components/schemas/RouterInfo"
          }
        },
        "required": [
          "router",
          "attempts"
        ]
      },
      "RouterInfo": {
        "externalDocs": {
          "url": ""
        },
        "title": "Router info",
        "description": "Information about a notification router.",
        "type": "object",
        "properties": {
          "routerId": {
            "example": "d4e5f678-90ab-cdef-1234-567890abcdef",
            "description": "Unique identifier of the router",
            "type": "string"
          },
          "routerName": {
            "example": "Production alerts router",
            "description": "Display name of the router",
            "type": "string"
          }
        },
        "required": [
          "routerId",
          "routerName"
        ]
      },
      "common.Group": {
        "type": "object",
        "properties": {
          "field": {
            "$ref": "#/components/schemas/FieldGroup"
          },
          "groups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/common.Group"
            }
          },
          "value": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "events.v3.FilterMatcher": {
        "type": "string",
        "enum": [
          "FILTER_MATCHER_TEXT_OR_UNSPECIFIED",
          "FILTER_MATCHER_REGEXP"
        ]
      },
      "v1.ConnectorType": {
        "type": "string",
        "enum": [
          "CONNECTOR_TYPE_UNSPECIFIED",
          "CONNECTOR_TYPE_SLACK",
          "CONNECTOR_TYPE_SERVICE_NOW",
          "CONNECTOR_TYPE_PAGER_DUTY",
          "CONNECTOR_TYPE_EMAIL",
          "CONNECTOR_TYPE_GENERIC_HTTPS"
        ]
      },
      "v3.FilterOperator": {
        "type": "string",
        "enum": [
          "FILTER_OPERATOR_AND_OR_UNSPECIFIED",
          "FILTER_OPERATOR_OR"
        ]
      }
    }
  }
}