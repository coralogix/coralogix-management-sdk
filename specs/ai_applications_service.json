{
  "openapi": "3.0.0",
  "info": {
    "title": "",
    "version": "1.0.0"
  },
  "paths": {
    "/ai/applications/v3": {
      "get": {
        "tags": [
          "AI Applications Service"
        ],
        "summary": "List AI applications",
        "description": "Lists AI applications, optionally filtered by evaluation type.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "AiApplicationsService_ListAiApplications",
        "parameters": [
          {
            "in": "query",
            "name": "page_size",
            "description": "Number of items per page. Default 200 if omitted.",
            "schema": {
              "description": "Number of items per page. Default 200 if omitted.",
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 1000
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "page_offset",
            "description": "Zero-based page offset. Default 0 if omitted.",
            "schema": {
              "description": "Zero-based page offset. Default 0 if omitted.",
              "type": "integer",
              "format": "int64",
              "minimum": 0,
              "maximum": 10000
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "evaluation_types",
            "description": "Optional filter: only include applications that have at least one evaluation of any of these types.",
            "schema": {
              "description": "Optional filter: only include applications that have at least one evaluation of any of these types.",
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/EvaluationType"
              },
              "minItems": 0,
              "maxItems": 100
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAiApplicationsResponse"
                },
                "example": {
                  "aiApplications": [
                    {
                      "application": "checkout",
                      "companyId": "12345",
                      "createdAt": "2026-06-02T15:30:00.000Z",
                      "guardrailsIntegrated": true,
                      "id": "175677d1-fc90-4a89-9e35-0590b188ebb2",
                      "subsystem": "api",
                      "updatedAt": "2026-06-02T15:35:00.000Z"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/applications/v3/{id}": {
      "get": {
        "tags": [
          "AI Applications Service"
        ],
        "summary": "Get AI application",
        "description": "Gets an AI application by its unique identifier.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "AiApplicationsService_GetAiApplicationById",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "Unique identifier of the AI application.",
            "required": true,
            "schema": {
              "description": "Unique identifier of the AI application.",
              "type": "string",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
              "minLength": 36,
              "maxLength": 36
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetAiApplicationByIdResponse"
                },
                "example": {
                  "aiApplication": {
                    "application": "checkout",
                    "companyId": "12345",
                    "createdAt": "2026-06-02T15:30:00.000Z",
                    "guardrailsIntegrated": true,
                    "id": "175677d1-fc90-4a89-9e35-0590b188ebb2",
                    "subsystem": "api",
                    "updatedAt": "2026-06-02T15:35:00.000Z"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "AI Applications Service"
        ],
        "summary": "Delete AI application",
        "description": "Deletes an AI application by its unique identifier.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "AiApplicationsService_DeleteAiApplication",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "Unique identifier of the AI application to delete.",
            "required": true,
            "schema": {
              "description": "Unique identifier of the AI application to delete.",
              "type": "string",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
              "minLength": 36,
              "maxLength": 36
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteAiApplicationResponse"
                },
                "example": {
                  "id": "175677d1-fc90-4a89-9e35-0590b188ebb2"
                }
              }
            }
          }
        }
      }
    },
    "/ai/model-pricing/v3": {
      "get": {
        "tags": [
          "AI Applications Service"
        ],
        "summary": "Get company model pricing",
        "description": "Returns the company-wide custom model pricing configuration.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "AiApplicationsService_GetCompanyModelPricing",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCompanyModelPricingResponse"
                },
                "example": {
                  "pricing": {
                    "companyId": "12345",
                    "id": "9d4f7c1a-2b3e-4f5a-8c1d-6e2f9a0b1c2d",
                    "prices": {
                      "gpt-4o": {
                        "inputPricePerMillionTokens": 2.5,
                        "outputPricePerMillionTokens": 10
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "AI Applications Service"
        ],
        "summary": "Set company model pricing",
        "description": "Replaces the company-wide custom model pricing configuration.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "AiApplicationsService_SetCompanyModelPricing",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "description": "Request to set (replace) the company's custom model pricing.",
                "type": "object",
                "properties": {
                  "prices": {
                    "description": "Full replacement map of model name to custom price.",
                    "type": "object",
                    "additionalProperties": {
                      "$ref": "#/components/schemas/ModelPrice"
                    }
                  }
                },
                "required": [
                  "prices"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetCompanyModelPricingResponse"
                },
                "example": {
                  "pricing": {
                    "companyId": "12345",
                    "id": "9d4f7c1a-2b3e-4f5a-8c1d-6e2f9a0b1c2d",
                    "prices": {
                      "gpt-4o": {
                        "inputPricePerMillionTokens": 2.5,
                        "outputPricePerMillionTokens": 10
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "AI Applications Service"
        ],
        "summary": "Delete company model pricing",
        "description": "Deletes the company-wide custom model pricing configuration.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "AiApplicationsService_DeleteCompanyModelPricing",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteCompanyModelPricingResponse"
                },
                "example": {
                  "id": "9d4f7c1a-2b3e-4f5a-8c1d-6e2f9a0b1c2d"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AiApplication": {
        "externalDocs": {
          "url": ""
        },
        "description": "AI Application",
        "type": "object",
        "properties": {
          "application": {
            "description": "Application name.",
            "type": "string",
            "pattern": "^[\\s\\S]+$",
            "minLength": 1,
            "maxLength": 256
          },
          "companyId": {
            "description": "Company ID",
            "type": "string",
            "pattern": "^[\\s\\S]+$",
            "minLength": 1,
            "maxLength": 256
          },
          "createdAt": {
            "description": "RFC3339 timestamp when the application was first observed.",
            "type": "string",
            "format": "date-time",
            "minLength": 20,
            "maxLength": 35
          },
          "guardrailsIntegrated": {
            "description": "Whether guardrails are integrated for this application.",
            "type": "boolean"
          },
          "id": {
            "description": "Unique identifier of the AI application.",
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
            "minLength": 36,
            "maxLength": 36
          },
          "subsystem": {
            "description": "Subsystem name",
            "type": "string",
            "pattern": "^[\\s\\S]+$",
            "minLength": 1,
            "maxLength": 256
          },
          "updatedAt": {
            "description": "RFC3339 timestamp when the application was last updated.",
            "type": "string",
            "format": "date-time",
            "minLength": 20,
            "maxLength": 35
          }
        }
      },
      "CompanyModelPricing": {
        "externalDocs": {
          "url": ""
        },
        "description": "Company-wide custom model pricing configuration.",
        "type": "object",
        "properties": {
          "companyId": {
            "description": "Company identifier.",
            "type": "string",
            "pattern": "^[\\s\\S]+$",
            "minLength": 1,
            "maxLength": 256
          },
          "id": {
            "description": "Unique identifier of the pricing record.",
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
            "minLength": 36,
            "maxLength": 36
          },
          "prices": {
            "description": "Map of model name to custom price. Replaces all existing prices on set.",
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/ModelPrice"
            }
          }
        }
      },
      "DeleteAiApplicationResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response returned after deleting an AI application.",
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier of the deleted AI application.",
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
            "minLength": 36,
            "maxLength": 36
          }
        }
      },
      "DeleteCompanyModelPricingResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response returned after deleting company model pricing.",
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier of the deleted pricing record.",
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
            "minLength": 36,
            "maxLength": 36
          }
        }
      },
      "EvaluationType": {
        "type": "string",
        "enum": [
          "ALLOWED_TOPICS",
          "COMPETITION",
          "HALLUCINATION_COMPLETENESS",
          "HALLUCINATION_CONTEXT_ADHERENCE",
          "HALLUCINATION_CONTEXT_RELEVANCE",
          "HALLUCINATION_CORRECTNESS",
          "PII",
          "PROMPT_INJECTION",
          "RESTRICTED_TOPICS",
          "SEXISM",
          "SQL_ALLOWED_TABLES",
          "SQL_HALLUCINATION",
          "SQL_READ_ONLY",
          "SQL_RESTRICTED_TABLES",
          "TOXICITY",
          "HALLUCINATION_TASK_ADHERENCE",
          "SQL_LOAD",
          "LANGUAGE_MISMATCH",
          "CUSTOM_EVALUATION"
        ]
      },
      "FilterPathAndValues": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FilterPathAndValuesFilters"
          },
          {
            "$ref": "#/components/schemas/FilterPathAndValuesMultipleValues"
          }
        ]
      },
      "FilterPathAndValuesFilters": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path",
          "values",
          "filters"
        ]
      },
      "FilterPathAndValuesMultipleValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path",
          "values",
          "multipleValues"
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            },
            "minItems": 0
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "GetAiApplicationByIdResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response containing the requested AI application.",
        "type": "object",
        "properties": {
          "aiApplication": {
            "$ref": "#/components/schemas/AiApplication"
          }
        }
      },
      "GetCompanyModelPricingResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response containing the company's custom model pricing.",
        "type": "object",
        "properties": {
          "pricing": {
            "$ref": "#/components/schemas/CompanyModelPricing"
          }
        }
      },
      "ListAiApplicationsResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response containing a page of AI applications.",
        "type": "object",
        "properties": {
          "aiApplications": {
            "description": "The list of AI applications on this page.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiApplication"
            },
            "minItems": 0,
            "maxItems": 1000
          }
        }
      },
      "ModelPrice": {
        "externalDocs": {
          "url": ""
        },
        "description": "Custom price for a single model, per one million tokens (USD).",
        "type": "object",
        "properties": {
          "cacheReadPricePerMillionTokens": {
            "description": "Cache read token price per one million tokens (USD).",
            "type": "number",
            "format": "double"
          },
          "cacheWritePricePerMillionTokens": {
            "description": "Cache write token price per one million tokens (USD).",
            "type": "number",
            "format": "double"
          },
          "inputPricePerMillionTokens": {
            "description": "Input token price per one million tokens (USD).",
            "type": "number",
            "format": "double"
          },
          "outputPricePerMillionTokens": {
            "description": "Output token price per one million tokens (USD).",
            "type": "number",
            "format": "double"
          }
        }
      },
      "MultipleValues": {
        "type": "object",
        "properties": {
          "matcher": {
            "$ref": "#/components/schemas/events.v3.FilterMatcher"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 0
            },
            "minItems": 0
          }
        }
      },
      "SetCompanyModelPricingResponse": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response containing the updated company model pricing.",
        "type": "object",
        "properties": {
          "pricing": {
            "$ref": "#/components/schemas/CompanyModelPricing"
          }
        }
      },
      "events.v3.FilterMatcher": {
        "type": "string",
        "enum": [
          "FILTER_MATCHER_TEXT_OR_UNSPECIFIED",
          "FILTER_MATCHER_REGEXP"
        ]
      },
      "v3.FilterOperator": {
        "description": "Filter operator.",
        "type": "string",
        "enum": [
          "FILTER_OPERATOR_AND_OR_UNSPECIFIED",
          "FILTER_OPERATOR_OR"
        ]
      }
    }
  }
}