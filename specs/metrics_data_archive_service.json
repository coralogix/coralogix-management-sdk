  "components": {
    "schemas": {
      "Error": {
        "description": "Standard error response body returned for a failed request.",
        "type": "object",
        "properties": {
          "code": {
            "description": "HTTP status code of the error (for example 400, 404, 500).",
            "type": "integer",
            "format": "int32",
            "minimum": 100,
            "maximum": 599
          },
          "message": {
            "description": "Human-readable description of the error.",
            "type": "string",
            "pattern": "^[\\s\\S]*$",
            "minLength": 0,
            "maxLength": 4096
          }
        }
      },
      "FilterPathAndValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string",
            "minLength": 0
          }
        },
        "required": [
          "path"
        ],
        "oneOf": [
          {
            "type": "object",
            "required": [
              "multipleValues"
            ]
          },
          {
            "type": "object",
            "required": [
              "filters"
            ]
          }
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            },
            "minItems": 0
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "GcsConfig": {
        "externalDocs": {
          "description": "Find out more about metrics cost optimization",
          "url": "https://coralogix.com/docs/user-guides/account-management/payment-and-billing/metrics-optimization/"
        },
        "title": "GCS Configuration",
        "description": "This data structure represents the GCS configuration for a tenant.",
        "type": "object",
        "properties": {
          "bucket": {
            "description": "Bucket name.",
            "type": "string",
            "minLength": 0
          }
        }
      },
      "GetTenantConfigResponseV2": {
        "externalDocs": {
          "url": ""
        },
        "description": "Response containing the current metrics tenant configuration.",
        "type": "object",
        "properties": {
          "tenantConfig": {
            "$ref": "#/components/schemas/TenantConfigV2"
          }
        }
      },
      "IbmConfigV2": {
        "externalDocs": {
          "description": "Find out more about metrics cost optimization",
          "url": "https://coralogix.com/docs/user-guides/account-management/payment-and-billing/metrics-optimization/"
        },
        "title": "IBM Bucket Configuration",
        "description": "This data structure is used to configure an IBM bucket.",
        "type": "object",
        "properties": {
          "crn": {
            "example": "crn:v1:bluemix:public:cloud-object-storage:global:a/1234567890abcdef1234567890abcdef:12345678-1234-1234-1234-1234567890ab::",
            "description": "The crn.",
            "type": "string",
            "minLength": 0
          },
          "endpoint": {
            "example": "s3.us-south.cloud-object-storage.appdomain.cloud",
            "description": "Endpoint.",
            "type": "string",
            "minLength": 0
          },
          "serviceCrn": {
            "example": "crn:v1:bluemix:public:cloud-object-storage:global:a/1234567890abcdef1234567890abcdef:12345678-1234-1234-1234-1234567890ab::",
            "description": "The service crn.",
            "type": "string",
            "minLength": 0
          }
        }
      },
      "MultipleValues": {
        "type": "object",
        "properties": {
          "matcher": {
            "$ref": "#/components/schemas/events.v3.FilterMatcher"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 0
            },
            "minItems": 0
          }
        }
      },
      "RetentionPolicyRequest": {
        "externalDocs": {
          "description": "Find out more about metrics cost optimization",
          "url": "https://coralogix.com/docs/user-guides/account-management/payment-and-billing/metrics-optimization/"
        },
        "title": "Retenion Policy Request",
        "description": "This data structure is used to set the retention policy for a tenant.",
        "type": "object",
        "properties": {
          "fiveMinutesResolution": {
            "example": 2,
            "description": "The five minutes resolution.",
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "oneHourResolution": {
            "example": 3,
            "description": "The one hour resolution.",
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "rawResolution": {
            "example": 1,
            "description": "The raw resolution.",
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "S3Config": {
        "externalDocs": {
          "description": "Find out more about metrics cost optimization",
          "url": "https://coralogix.com/docs/user-guides/account-management/payment-and-billing/metrics-optimization/"
        },
        "title": "S3 Configuration",
        "description": "This data structure represents the S3 configuration for a tenant.",
        "type": "object",
        "properties": {
          "bucket": {
            "description": "Bucket name.",
            "type": "string",
            "minLength": 0
          },
          "region": {
            "description": "Region.",
            "type": "string",
            "minLength": 0
          }
        }
      },
      "TenantConfigV2": {
        "externalDocs": {
          "url": ""
        },
        "description": "Tenant config v2.",
        "type": "object",
        "properties": {
          "disabled": {
            "description": "Whether metrics archiving is disabled for this tenant.",
            "type": "boolean"
          },
          "gcs": {
            "$ref": "#/components/schemas/GcsConfig"
          },
          "ibm": {
            "$ref": "#/components/schemas/IbmConfigV2"
          },
          "prefix": {
            "description": "Storage path prefix applied to all archived objects.",
            "type": "string",
            "minLength": 0
          },
          "retentionPolicy": {
            "$ref": "#/components/schemas/RetentionPolicyRequest"
          },
          "s3": {
            "$ref": "#/components/schemas/S3Config"
          },
          "tenantId": {
            "description": "Tenant identifier.",
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        },
        "oneOf": [
          {
            "type": "object",
            "required": [
              "ibm"
            ]
          },
          {
            "type": "object",
            "required": [
              "s3"
            ]
          },
          {
            "type": "object",
            "required": [
              "gcs"
            ]
          },
          {
            "type": "object",
            "not": {
              "anyOf": [
                {
                  "type": "object",
                  "required": [
                    "ibm"
                  ]
                },
                {
                  "type": "object",
                  "required": [
                    "s3"
                  ]
                },
                {
                  "type": "object",
                  "required": [
                    "gcs"
                  ]
                }
              ]
            }
          }
        ]
      },
      "events.v3.FilterMatcher": {
        "type": "string",
        "enum": [
          "FILTER_MATCHER_TEXT_OR_UNSPECIFIED",
          "FILTER_MATCHER_REGEXP"
        ]
      },
      "v3.FilterOperator": {
        "description": "Filter operator.",
        "type": "string",
        "enum": [
          "FILTER_OPERATOR_AND_OR_UNSPECIFIED",
          "FILTER_OPERATOR_OR"
        ]
      }
    }
  }
}