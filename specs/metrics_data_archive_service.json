    "/metrics/data-setup/v1/validate": {
      "post": {
        "tags": [
          "Metrics Data Archive Service"
        ],
        "summary": "Validate Metrics Storage Bucket",
        "description": "Validates the provided metrics storage configuration.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "MetricsConfiguratorPublicService_ValidateBucket",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Bucket Validation Request",
                "description": "This data structure is used to validate a bucket.",
                "type": "object",
                "properties": {
                  "gcs": {
                    "$ref": "#/components/schemas/GcsConfig"
                  },
                  "ibm": {
                    "$ref": "#/components/schemas/IbmConfigV2"
                  },
                  "s3": {
                    "$ref": "#/components/schemas/S3Config"
                  }
                },
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "ibm"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "s3"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "gcs"
                    ]
                  },
                  {
                    "type": "object",
                    "not": {
                      "anyOf": [
                        {
                          "type": "object",
                          "required": [
                            "ibm"
                          ]
                        },
                        {
                          "type": "object",
                          "required": [
                            "s3"
                          ]
                        },
                        {
                          "type": "object",
                          "required": [
                            "gcs"
                          ]
                        }
                      ]
                    }
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
