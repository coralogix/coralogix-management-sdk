  "paths": {
    "/integrations/testing/v1/extensions": {
      "post": {
        "tags": [
          "Extension testing service"
        ],
        "summary": "Test extension revision",
        "description": "Tests an extension revision.\n\nRequires the following permissions:\n- `extensions:UpdateConfig`",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ExtensionTestingService_TestExtensionRevision",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Test extension revision request",
                "description": "Request for testing an extension revision.",
                "type": "object",
                "properties": {
                  "cleanupAfterTest": {
                    "description": "Whether to automatically clean up the testing extension revision after the test run completes.",
                    "type": "boolean"
                  },
                  "extensionData": {
                    "$ref": "#/components/schemas/ExtensionData"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestExtensionRevisionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {}
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {}
            }
          }
        },
        "x-coralogixPermissions": [
          "extensions:UpdateConfig"
        ]
      },
      "delete": {
        "tags": [
          "Extension testing service"
        ],
        "summary": "Cleanup testing extension",
        "description": "Removes the testing revision of an extension.\n\nRequires the following permissions:\n- `extensions:UpdateConfig`",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ExtensionTestingService_CleanupTestingRevision",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Cleanup testing revision request",
                "description": "Request for cleaning up an extension testing revision.",
                "type": "object",
                "properties": {
                  "id": {
                    "description": "ID of the testing extension revision to delete.",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CleanupTestingRevisionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {}
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {}
            }
          }
        },
        "x-coralogixPermissions": [
          "extensions:UpdateConfig"
        ]
      }
    },
    "/integrations/testing/v1/extensions/initialize": {
      "post": {
        "tags": [
          "Extension testing service"
        ],
        "summary": "Initialize testing revision",
        "description": "Initializes a testing revision for an extension.\n\nRequires the following permissions:\n- `extensions:UpdateConfig`",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ExtensionTestingService_InitializeTestingRevision",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Initialize testing revision request",
                "description": "Request for initializing an extension testing revision.",
                "type": "object",
                "properties": {
                  "extensionData": {
                    "$ref": "#/components/schemas/ExtensionData"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitializeTestingRevisionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {}
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {}
            }
          }
        },
        "x-coralogixPermissions": [
          "extensions:UpdateConfig"
        ]
      }
    }
  },
