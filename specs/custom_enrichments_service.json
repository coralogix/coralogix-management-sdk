    "/enrichment-rules/custom-enrichment-rules/v1/all/contents": {
      "post": {
        "tags": [
          "Custom Enrichments Service"
        ],
        "summary": "Search Custom Enrichment Data",
        "description": "Returns the contents of all custom enrichment data.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CustomEnrichmentService_SearchCustomEnrichmentData",
        "parameters": [
          {
            "in": "query",
            "name": "search_clauses",
            "description": "Search clauses used to filter custom enrichment data.",
            "schema": {
              "description": "Search clauses used to filter custom enrichment data.",
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/SearchClauseId"
                  },
                  {
                    "$ref": "#/components/schemas/SearchClauseName"
                  }
                ]
              },
              "minItems": 0
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchCustomEnrichmentDataResponse"
                }
              }
            }
          }
        }
      }
