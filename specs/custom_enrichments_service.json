          "url": ""
        },
        "operationId": "CustomEnrichmentService_DeleteCustomEnrichment",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "The unique identifier of the custom enrichment rule to delete.",
            "required": true,
            "schema": {
              "example": 1,
              "description": "The unique identifier of the custom enrichment rule to delete.",
              "type": "integer",
              "format": "int64",
              "minimum": 0
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteCustomEnrichmentResponse"
                }
              }
            }
          }
        }
      }
    }
