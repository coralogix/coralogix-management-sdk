          "url": ""
        },
        "operationId": "CustomEnrichmentService_CreateCustomEnrichment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Create Custom Enrichment Request",
                "description": "This request data structure is used to create a custom enrichment",
                "type": "object",
                "properties": {
                  "description": {
                    "example": "custom_enrichment_description",
                    "description": "Human-readable description of the custom enrichment.",
                    "type": "string",
                    "minLength": 0
                  },
                  "file": {
                    "$ref": "#/components/schemas/File"
                  },
                  "name": {
                    "example": "custom_enrichment_name",
                    "description": "Human-readable name for the custom enrichment.",
                    "type": "string",
                    "minLength": 0
                  }
                },
                "required": [
                  "name",
                  "description",
                  "file"
                ]
              }
            }
          },
          "required": true
