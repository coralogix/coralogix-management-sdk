    "/enrichment-rules/custom-enrichment-rules/v1/{id}": {
      "get": {
        "tags": [
          "Custom Enrichments Service"
        ],
        "summary": "Get Custom Enrichment",
        "description": "Returns the details of the specified custom enrichment rule.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CustomEnrichmentService_GetCustomEnrichment",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "The unique identifier of the custom enrichment rule.",
            "required": true,
            "schema": {
              "example": 1,
              "description": "The unique identifier of the custom enrichment rule.",
              "type": "integer",
              "format": "int64",
              "minimum": 0
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCustomEnrichmentResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Custom Enrichments Service"
