  "paths": {
    "/enrichment-rules/custom-enrichment-rules/v1": {
      "get": {
        "tags": [
          "Custom Enrichments Service"
        ],
        "summary": "Get Custom Enrichments",
        "description": "Returns all custom enrichment rules.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CustomEnrichmentService_GetCustomEnrichments",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCustomEnrichmentsResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Custom Enrichments Service"
        ],
        "summary": "Update Custom Enrichment",
        "description": "Updates a custom enrichment rule.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "CustomEnrichmentService_UpdateCustomEnrichment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Update Custom Enrichment Request",
                "description": "This request data structure is used to update a custom enrichment",
                "type": "object",
                "properties": {
                  "customEnrichmentId": {
                    "example": 1,
                    "description": "The custom enrichment id.",
                    "type": "integer",
                    "format": "int64",
                    "minimum": 0
                  },
                  "description": {
                    "example": "custom_enrichment_description",
                    "description": "New human-readable description of the custom enrichment.",
                    "type": "string",
                    "minLength": 0
                  },
                  "file": {
                    "$ref": "#/components/schemas/File"
                  },
                  "name": {
                    "example": "custom_enrichment_name",
                    "description": "New human-readable name for the custom enrichment.",
                    "type": "string",
                    "minLength": 0
                  }
                },
                "required": [
                  "customEnrichmentId",
                  "name",
                  "description",
                  "file"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateCustomEnrichmentResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Custom Enrichments Service"
        ],
        "summary": "Create Custom Enrichments",
        "description": "Creates a new custom enrichment rule.",
