              "description": "Team ID to search within",
              "type": "integer",
              "format": "int64"
            },
            "style": "simple"
          },
          {
            "in": "path",
            "name": "user_account_id",
            "required": true,
            "schema": {
              "description": "User account ID to retrieve",
              "type": "integer",
              "format": "int64"
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetUserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {}
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {}
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {}
            }
          }
        }
      }
    },
    "/aaa/teams/v2/{team_id}/search": {
      "get": {
        "tags": [
          "Users Management Service"
        ],
        "summary": "Search Users",
        "externalDocs": {
          "url": ""
        },
        "operationId": "UsersMgmtService_SearchUsers",
        "parameters": [
          {
            "in": "path",
            "name": "team_id",
            "required": true,
            "schema": {
              "description": "Team ID to search within",
              "type": "integer",
              "format": "int64"
            },
            "style": "simple"
          },
          {
            "in": "query",
            "name": "username",
            "schema": {
              "example": "",
              "description": "Optional filter by username (partial match supported)",
              "type": "string"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "$ref": "#/components/schemas/UserStatus"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "page_size",
            "schema": {
              "description": "Number of results per page",
              "type": "integer",
              "format": "int64"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "page_token",
            "schema": {
              "description": "Token for pagination to retrieve the next page of results",
              "type": "integer",
              "format": "int64"
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchUsersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {}
            }
          },
          "401": {
            "description": "Unauthorized request",
            "content": {
              "application/json": {}
            }
          },
          "404": {
            "description": "Team not found",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {}
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessType": {
        "discriminator": {
          "propertyName": "access_type",
          "mapping": {
            "permanent": "#/components/schemas/PermanentAccess",
            "temporary": "#/components/schemas/TemporaryAccess"
          }
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/AccessTypeTemporaryAccess"
          },
          {
            "$ref": "#/components/schemas/AccessTypePermanentAccess"
          }
        ]
      },
      "AccessTypePermanentAccess": {
        "externalDocs": {
          "url": ""
        },
        "title": "AccessType",
        "description": "Defines the access duration for a user. Can be either permanent (indefinite) or temporary (expires at a specific time).",
        "type": "object",
        "properties": {
          "accessType": {
            "description": "Type of access: 'permanent' or 'temporary'",
            "type": "string"
          },
          "permanentAccess": {
            "$ref": "#/components/schemas/PermanentAccess"
          }
        },
        "required": [
          "accessType",
          "permanentAccess"
        ]
      },
      "AccessTypeTemporaryAccess": {
        "externalDocs": {
          "url": ""
        },
        "title": "AccessType",
        "description": "Defines the access duration for a user. Can be either permanent (indefinite) or temporary (expires at a specific time).",
        "type": "object",
        "properties": {
          "accessType": {
            "description": "Type of access: 'permanent' or 'temporary'",
            "type": "string"
          },
          "temporaryAccess": {
            "$ref": "#/components/schemas/TemporaryAccess"
          }
        },
        "required": [
          "accessType",
          "temporaryAccess"
        ]
      },
      "AllowedLoginMode": {
        "type": "string",
        "enum": [
          "ALLOWED_LOGIN_MODE_UNSPECIFIED",
          "ALLOWED_LOGIN_MODE_SSO",
          "ALLOWED_LOGIN_MODE_LOCAL"
        ]
      },
      "ColorsByAggregation": {
        "type": "object",
        "properties": {
          "aggregation": {
            "$ref": "#/components/schemas/ColorsByAggregation"
          }
        },
        "required": [
          "aggregation"
        ]
      },
      "ColorsByCategory": {
        "type": "object",
        "properties": {
          "category": {
            "$ref": "#/components/schemas/ColorsByCategory"
          }
        },
        "required": [
          "category"
        ]
      },
      "ColorsByGroupBy": {
        "type": "object",
        "properties": {
          "groupBy": {
            "$ref": "#/components/schemas/ColorsByGroupBy"
          }
        },
        "required": [
          "groupBy"
        ]
      },
      "ColorsByQuery": {
        "type": "object",
        "properties": {
          "query": {
            "$ref": "#/components/schemas/ColorsByQuery"
          }
        },
        "required": [
          "query"
        ]
      },
      "ColorsByStack": {
        "type": "object",
        "properties": {
          "stack": {
            "$ref": "#/components/schemas/ColorsByStack"
          }
        },
        "required": [
          "stack"
        ]
      },
      "CreateUsersResponse": {
        "externalDocs": {
          "description": "Find out more about user management",
          "url": "https://coralogix.com/docs/user-guides/account-management/user-management/assign-user-roles-and-scopes-via-groups/"
        },
        "title": "CreateUsersResponse",
        "description": "Empty response indicating successful processing of all user creation and invitation requests. Ensure failures are returned via gRPC status codes.",
        "type": "object"
      },
      "FieldGroup": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "FilterPathAndValues": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FilterPathAndValuesFilters"
          },
          {
            "$ref": "#/components/schemas/FilterPathAndValuesMultipleValues"
          }
        ]
      },
      "FilterPathAndValuesFilters": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "filters": {
            "$ref": "#/components/schemas/Filters"
          },
          "path": {
            "example": "test",
            "type": "string"
          }
        },
        "required": [
          "path",
          "values",
          "filters"
        ]
      },
      "FilterPathAndValuesMultipleValues": {
        "externalDocs": {
          "url": ""
        },
        "title": "FilterPathAndValues",
        "description": "This data structure represents a filter path and values",
        "type": "object",
        "properties": {
          "multipleValues": {
            "$ref": "#/components/schemas/MultipleValues"
          },
          "path": {
            "example": "test",
            "type": "string"
          }
        },
        "required": [
          "path",
          "values",
          "multipleValues"
        ]
      },
      "Filters": {
        "externalDocs": {
          "url": ""
        },
        "title": "Filters",
        "description": "This data structure represents a filter",
        "type": "object",
        "properties": {
          "operator": {
            "$ref": "#/components/schemas/v3.FilterOperator"
          },
          "pathAndValues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterPathAndValues"
            }
          }
        },
        "required": [
          "pathAndValues"
        ]
      },
      "GetUserResponse": {
        "externalDocs": {
          "description": "Find out more about user management",
          "url": "https://coralogix.com/docs/user-guides/account-management/user-management/assign-user-roles-and-scopes-via-groups/"
        },
        "title": "GetUserResponse",
        "description": "Response containing the complete details of the requested user, including account information, status, login modes, and access configuration.",
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/rbac.v2.User"
          }
        }
      },
      "MinMaxAuto": {
        "externalDocs": {
          "url": ""
        },
        "title": "Min-Max",
        "description": "Definition of min/max value configuration, can be automatically derived from data or custom",
        "type": "object",
        "properties": {
          "auto": {
            "$ref": "#/components/schemas/MinMaxAuto"
          }
        },
        "required": [
          "auto"
        ]
      },
      "MinMaxCustom": {
        "externalDocs": {
          "url": ""
        },
        "title": "Min-Max",
        "description": "Definition of min/max value configuration, can be automatically derived from data or custom",
        "type": "object",
        "properties": {
          "custom": {
            "$ref": "#/components/schemas/MinMaxCustom"
          }
        },
        "required": [
          "custom"
        ]
      },
      "MultipleValues": {
        "type": "object",
        "properties": {
          "matcher": {
            "$ref": "#/components/schemas/events.v3.FilterMatcher"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "OnboardingMode": {
        "type": "string",
        "enum": [
          "ONBOARDING_MODE_UNSPECIFIED",
          "ONBOARDING_MODE_INVITE_LINK",
          "ONBOARDING_MODE_NO_INVITE"
        ]
      },
      "PermanentAccess": {
        "externalDocs": {
          "url": ""
        },
        "title": "PermanentAccess",
        "description": "User with permanent access. The user's access does not expire and remains active until manually revoked or deactivated.",
        "type": "object"
      },
      "SearchUsersResponse": {
        "externalDocs": {
          "description": "Find out more about user management",
          "url": "https://coralogix.com/docs/user-guides/account-management/user-management/assign-user-roles-and-scopes-via-groups/"
        },
        "title": "SearchUsersResponse",
        "description": "Response containing a paginated list of users matching the search criteria, along with pagination tokens and total count.",
        "type": "object",
        "properties": {
          "nextPageToken": {
            "description": "Token for the next page of results. Empty if no more pages available.",
            "type": "integer",
            "format": "int64"
          },
          "totalCount": {
            "description": "Total number of users matching the search criteria across all pages",
            "type": "integer",
            "format": "int64"
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/rbac.v2.User"
            }
          }
        }
      },
      "TemporaryAccess": {
        "externalDocs": {
          "url": ""
        },
        "title": "TemporaryAccess",
        "description": "User with temporary access. The user's access will automatically expire at the specified timestamp.",
        "type": "object",
        "properties": {
          "expireAt": {
            "example": "2021-01-01T00:00:00Z",
            "description": "Timestamp when the user's temporary access will expire. After this time, the user will no longer be able to access the system.",
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateUsersResponse": {
        "externalDocs": {
          "description": "Find out more about user management",
          "url": "https://coralogix.com/docs/user-guides/account-management/user-management/assign-user-roles-and-scopes-via-groups/"
        },
        "title": "UpdateUsersResponse",
        "description": "Response confirming the successful update of users. Contains the user account IDs of all users that were updated.",
        "type": "object",
        "properties": {
          "userAccountIds": {
            "type": "array",
            "items": {
              "description": "List of user account IDs for the successfully updated users",
              "type": "integer",
              "format": "int64"
            }
          }
        }
      },
      "UpdateUsersStatusesResponse": {
        "externalDocs": {
          "description": "Find out more about user management",
          "url": "https://coralogix.com/docs/user-guides/account-management/user-management/assign-user-roles-and-scopes-via-groups/"
        },
        "title": "UpdateUserStatusResponse",
        "description": "Response confirming the successful status update of users. Contains the user account IDs of all users whose status was changed.",
        "type": "object",
        "properties": {
          "userAccountIds": {
            "type": "array",
            "items": {
              "description": "List of user account IDs for users whose status was successfully updated",
              "type": "integer",
              "format": "int64"
            }
          }
        }
      },
      "UserStatus": {
        "type": "string",
        "enum": [
          "USER_STATUS_UNSPECIFIED",
          "USER_STATUS_ACTIVE",
          "USER_STATUS_INACTIVE"
        ]
      },
      "UserTemplate": {
        "externalDocs": {
          "description": "Find out more about user management",
          "url": "https://coralogix.com/docs/user-guides/account-management/user-management/assign-user-roles-and-scopes-via-groups/"
        },
        "title": "UserTemplate",
        "description": "Template containing all user properties that can be set when creating or updating a user. Includes personal information, status, authentication methods, and access duration.",
        "type": "object",
        "properties": {
          "accessType": {
            "$ref": "#/components/schemas/AccessType"
          },
          "allowedLoginMode": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AllowedLoginMode"
            }
          },
          "firstName": {
            "description": "User's first name",
            "type": "string"
          },
          "lastName": {
            "description": "User's last name",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/UserStatus"
          },
          "username": {
            "description": "Unique username for the user. Must be unique within the system. Updating username for existing users is not supported and ignored.",
            "type": "string"
          }
        }
      },
      "common.Group": {
        "type": "object",
        "properties": {
          "field": {
            "$ref": "#/components/schemas/FieldGroup"
          },
          "groups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/common.Group"
            }
          },
          "value": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "events.v3.FilterMatcher": {
        "type": "string",
        "enum": [
          "FILTER_MATCHER_TEXT_OR_UNSPECIFIED",
          "FILTER_MATCHER_REGEXP"
        ]
      },
      "rbac.v2.User": {
        "externalDocs": {
          "url": ""
        },
        "title": "User",
        "description": "A user is an entity that is always part of a team and has an account associated with it",
        "type": "object",
        "properties": {
          "firstName": {
            "description": "User first name",
            "type": "string"
          },
          "lastName": {
            "description": "User last name",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/UserStatus"
          },
          "userAccountId": {
            "description": "Associated account id. An account can have many users.",
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "description": "Unique user id",
            "type": "string"
          },
          "username": {
            "description": "Unique username",
            "type": "string"
          }
        }
      },
      "v3.FilterOperator": {
        "type": "string",
        "enum": [
          "FILTER_OPERATOR_AND_OR_UNSPECIFIED",
          "FILTER_OPERATOR_OR"
        ]
      }
    }
  }
}