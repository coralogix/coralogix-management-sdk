            "schema": {
              "description": "Team ID where the users will be created",
              "type": "integer",
              "format": "int64"
            },
            "style": "simple"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "onboardingMode": {
                    "$ref": "#/components/schemas/OnboardingMode"
                  },
                  "userTemplate": {
                    "$ref": "#/components/schemas/UserTemplate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateUsersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
