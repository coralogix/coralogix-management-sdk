    "/aaa/team-scopes/v1/{id}": {
      "delete": {
        "tags": [
          "Scopes Service"
        ],
        "summary": "Delete Scope",
        "description": "Deletes the data access scope with the specified ID.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ScopesService_DeleteScope",
        "parameters": [
          {
            "in": "path",
            "name": "id",
