            "description": "Filter connectors by their type.",
            "schema": {
              "$ref": "#/components/schemas/notification_center.ConnectorType"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "supported_by_entity_type",
            "description": "Filter connectors by the entity type they support.",
            "schema": {
