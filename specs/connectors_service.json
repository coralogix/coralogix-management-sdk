        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReplaceConnectorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Connectors service"
        ],
        "summary": "Create a Connector",
        "description": "Creates a new notification connector.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ConnectorsService_CreateConnector",
        "requestBody": {
          "content": {
            "application/json": {
