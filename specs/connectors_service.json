        "tags": [
          "Connectors service"
        ],
        "summary": "List Connectors",
        "description": "Returns notification connectors with optional pagination.",
        "externalDocs": {
          "url": ""
        },
        "operationId": "ConnectorsService_ListConnectors",
        "parameters": [
          {
            "in": "query",
